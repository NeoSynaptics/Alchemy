# Alchemy Configuration
# Copy to .env and adjust as needed: cp .env.example .env

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_CPU_MODEL=rashakol/UI-TARS-72B-DPO
OLLAMA_KEEP_ALIVE=10m

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Auth (optional) ---
AUTH_TOKEN=
REQUIRE_AUTH=false

# --- Shadow Desktop (WSL2) ---
WSL_DISTRO=Ubuntu
SHADOW_WSL_REPO_PATH=/mnt/c/Users/info/GitHub/Alchemy
DISPLAY_NUM=99
VNC_PORT=5900
NOVNC_PORT=6080
RESOLUTION=1920x1080x24

# --- Agent ---
AGENT_MAX_STEPS=50
AGENT_SCREENSHOT_INTERVAL=1.0
AGENT_TIMEOUT=300.0
AGENT_APPROVAL_TIMEOUT=60.0
AGENT_HISTORY_WINDOW=8
