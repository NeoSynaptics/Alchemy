# Alchemy Configuration
# Copy to .env and adjust as needed: cp .env.example .env
#
# Nested settings use double-underscore delimiter:
#   NEOSY__SRC_PATH=/path/to/BaratzaMemory/src
# Flat settings use single underscore (legacy, still works):
#   GATE_ENABLED=false

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_CPU_MODEL=rashakol/UI-TARS-72B-DPO
OLLAMA_KEEP_ALIVE=10m

# --- Auth (optional) ---
AUTH_TOKEN=
REQUIRE_AUTH=false

# --- Agent / Click ---
AGENT_MAX_STEPS=50
AGENT_SCREENSHOT_INTERVAL=1.0
AGENT_TIMEOUT=300.0
AGENT_APPROVAL_TIMEOUT=60.0
AGENT_HISTORY_WINDOW=8
CLICK__OMNIPARSER_DEVICE=cuda:0

# --- Paths ---
# AlchemyMemory storage (relative to repo root, or absolute)
MEMORY__STORAGE_PATH=./data/memory
# Chroma vector DB path (defaults to {storage_path}/chroma if empty)
MEMORY__CHROMA_PATH=

# --- NEOSY (knowledge graph) ---
# Path to BaratzaMemory/src — empty = NEOSY routes not mounted
NEOSY__SRC_PATH=
NEOSY__ENABLED=true
NEOSY__PG_HOST=localhost
NEOSY__PG_PORT=5432
NEOSY__PG_USER=baratza
NEOSY__PG_PASSWORD=baratza_dev
NEOSY__PG_DATABASE=baratza_knowledge
NEOSY__QDRANT_HOST=localhost
NEOSY__QDRANT_PORT=6333

# --- GPU / APU ---
# OmniParser device (cuda:0, cuda:1, cpu)
# CLICK__OMNIPARSER_DEVICE=cuda:0

# --- Memory models ---
MEMORY__SUMMARIZER_MODEL=qwen2.5vl:7b
MEMORY__EMBEDDER_MODEL=nomic-embed-text
MEMORY__SYNTHESIS_MODEL=qwen3:14b
MEMORY__CLASSIFIER_MODEL=qwen3:3b

# --- Voice ---
VOICE__ENABLED=true
# VOICE__WAKE_WORD_MODEL=hey_alchemy

# --- Gate ---
GATE__ENABLED=true

# --- Desktop ---
DESKTOP__ENABLED=true

# --- Research ---
RESEARCH__ENABLED=true
